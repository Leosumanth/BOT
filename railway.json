{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build",
    "watchPatterns": [
      "/apps/backend/**",
      "/apps/frontend/**",
      "/packages/bot/**",
      "/packages/blockchain/**",
      "/packages/shared/**",
      "/package.json",
      "/package-lock.json",
      "/tsconfig.json",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
