# Shared
NODE_ENV=development
APP_ENV=development
LOG_LEVEL=debug

# Backend
BACKEND_PORT=4000
API_PREFIX=api
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:3000
# Keep this on localhost for local development or when the backend serves the built frontend on the same Railway service.
# Set a public URL only when the frontend is deployed as a separate service.
# Railway backend service example:
# FRONTEND_URL=https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mintbot

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
MINT_QUEUE_NAME=mint-jobs
TRACKER_QUEUE_NAME=tracker-jobs
ENABLE_RUST_EXECUTOR=true
RUST_MINT_QUEUE_NAME=rust:mint
RUST_RESULT_CHANNEL=rust:mint:results
RUST_EXECUTION_TIMEOUT_MS=45000
RUST_SUCCESS_RESULT_TTL_MS=600000
BLOCK_MONITOR_INTERVAL_MS=1000
ENABLE_INLINE_WORKER=true
ENABLE_MEMPOOL_TRACKER=true

# Wallet encryption
PRIVATE_KEY_ENCRYPTION_SECRET=replace-with-32-byte-secret

# RPC endpoints
ETHEREUM_RPC_HTTP_ALCHEMY=https://eth-mainnet.g.alchemy.com/v2/your-key
ETHEREUM_RPC_HTTP_QUICKNODE=https://your-quicknode-endpoint.quiknode.pro/your-key/
ETHEREUM_RPC_WS_ALCHEMY=wss://eth-mainnet.g.alchemy.com/v2/your-key
ETHEREUM_RPC_WS_QUICKNODE=wss://your-quicknode-endpoint.quiknode.pro/your-key/

# Flashbots
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_AUTH_PRIVATE_KEY=0xyourflashbotsauthkey

# Rust worker
RUST_WORKER_REDIS_URL=redis://localhost:6379
RUST_WORKER_QUEUE_NAME=rust:mint
RUST_WORKER_RESULT_CHANNEL=rust:mint:results

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=walletconnect-project-id
# Leave NEXT_PUBLIC_API_URL and NEXT_PUBLIC_SOCKET_URL unset in Railway when the backend serves the built frontend on the same public domain.
# Railway frontend service examples:
# NEXT_PUBLIC_API_URL=https://${{backend.RAILWAY_PUBLIC_DOMAIN}}/api
# NEXT_PUBLIC_SOCKET_URL=https://${{backend.RAILWAY_PUBLIC_DOMAIN}}
